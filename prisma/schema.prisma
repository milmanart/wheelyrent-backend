generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id                   Int       @id @default(autoincrement())
  name                 String
  email                String    @unique
  password             String
  role                 Role      @default(CLIENT)
  city                 String?
  phone                String?
  birthDate            String?
  about                String?
  avatarUri            String?
  notifPromocje        Boolean   @default(true)
  notifAktualnosci     Boolean   @default(true)
  notifTransakcje      Boolean   @default(true)
  drivingLicenseNumber String?
  drivingLicenseExpiry String?
  drivingLicensePhotoUri String?
  idCardNumber         String?
  idCardExpiry         String?
  idCardPhotoUri       String?
  createdAt            DateTime  @default(now())
  bookings             Booking[]
  reviews              Review[]
  cards                PaymentCard[]
}

enum Role {
  CLIENT
  ADMIN
}

model Car {
  id           Int       @id @default(autoincrement())
  brand        String
  model        String
  year         Int
  pricePerDay  Float
  imageUrl     String?
  available    Boolean   @default(true)
  fuelType     String?
  seats        Int?
  transmission String?
  description  String?
  source       String?
  externalId   String?
  latitude     Float?
  longitude    Float?
  bookings     Booking[]
  reviews      Review[]
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt
}

model Booking {
  id         Int           @id @default(autoincrement())
  userId     Int
  carId      Int
  startDate  DateTime
  endDate    DateTime
  status     BookingStatus @default(ACTIVE)
  totalPrice Float
  extrasCost Float         @default(0)
  extras     String?
  createdAt  DateTime      @default(now())
  user       User          @relation(fields: [userId], references: [id])
  car        Car           @relation(fields: [carId], references: [id])
}

model PaymentCard {
  id        Int      @id @default(autoincrement())
  userId    Int
  type      String
  last4     String
  createdAt DateTime @default(now())
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

enum BookingStatus {
  ACTIVE
  CANCELLED
  COMPLETED
}

model Review {
  id        Int      @id @default(autoincrement())
  carId     Int
  userId    Int
  stars     Int
  text      String?
  createdAt DateTime @default(now())
  car       Car      @relation(fields: [carId], references: [id])
  user      User     @relation(fields: [userId], references: [id])
}
